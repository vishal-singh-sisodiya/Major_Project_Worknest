# MongoDB Atlas → Connect → Drivers → URI (replace password)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/worknest?retryWrites=true&w=majority

JWT_SECRET=use-a-long-random-string-at-least-32-characters

# Frontend URL(s) allowed by CORS and Socket.IO (comma-separated if multiple)
CLIENT_URL=http://localhost:5173

# Same origin you use below for VITE_API_URL in production, no trailing slash, no /api suffix
PORT=5000

# Required for AI routes (Groq console)
GROQ_API_KEY=
